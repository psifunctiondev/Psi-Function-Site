[Unit]
Description=Consulting Site Gunicorn Service
After=network.target

[Service]
User=deploy
Group=www-data
WorkingDirectory=/opt/consulting-site/current
EnvironmentFile=-/opt/consulting-site/shared/env/app.env
RuntimeDirectory=consulting-site
RuntimeDirectoryMode=0755
UMask=0027

ExecStart=/opt/consulting-site/current/.venv/bin/gunicorn \
  --workers 3 \
  --bind unix:/run/consulting-site/gunicorn.sock \
  --access-logfile - \
  --error-logfile - \
  wsgi:app

Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
